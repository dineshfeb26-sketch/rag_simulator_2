<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RAG Simulator</title>
  <style>
    :root {
      --bg: #07111f;
      --panel: rgba(255, 255, 255, 0.08);
      --panel-strong: rgba(255, 255, 255, 0.13);
      --text: #ecf7ff;
      --muted: #9bb2c7;
      --accent: #55e6c1;
      --accent-2: #8b5cf6;
      --warning: #ffd166;
      --danger: #ff6b6b;
      --line: rgba(255, 255, 255, 0.18);
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
      --radius: 24px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(85, 230, 193, 0.25), transparent 30%),
        radial-gradient(circle at top right, rgba(139, 92, 246, 0.25), transparent 30%),
        linear-gradient(135deg, #07111f 0%, #0b1630 45%, #0b1020 100%);
      min-height: 100vh;
      padding: 28px;
    }

    .app {
      max-width: 1320px;
      margin: 0 auto;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 22px;
      align-items: stretch;
      margin-bottom: 22px;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .intro {
      padding: 32px;
      position: relative;
      overflow: hidden;
    }

    .intro::after {
      content: "";
      position: absolute;
      width: 240px;
      height: 240px;
      border-radius: 999px;
      right: -80px;
      top: -80px;
      background: radial-gradient(circle, rgba(85, 230, 193, 0.28), transparent 65%);
      pointer-events: none;
    }

    h1 {
      font-size: clamp(32px, 5vw, 58px);
      line-height: 0.95;
      margin: 0 0 16px;
      letter-spacing: -0.05em;
    }

    .gradient {
      background: linear-gradient(90deg, var(--accent), #79a7ff, var(--accent-2));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .subtitle {
      color: var(--muted);
      font-size: 17px;
      line-height: 1.7;
      max-width: 760px;
      margin: 0;
    }

    .quick-explain {
      padding: 28px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 18px;
    }

    .metric {
      display: grid;
      grid-template-columns: 44px 1fr;
      gap: 12px;
      align-items: center;
      padding: 14px;
      background: rgba(255, 255, 255, 0.07);
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .metric span:first-child {
      width: 44px;
      height: 44px;
      display: grid;
      place-items: center;
      border-radius: 15px;
      background: linear-gradient(135deg, rgba(85, 230, 193, 0.25), rgba(139, 92, 246, 0.25));
      font-size: 22px;
    }

    .metric strong {
      display: block;
      font-size: 14px;
    }

    .metric small {
      display: block;
      color: var(--muted);
      margin-top: 3px;
      line-height: 1.4;
    }

    .workspace {
      display: grid;
      grid-template-columns: 390px 1fr;
      gap: 22px;
    }

    .control-panel {
      padding: 22px;
      position: sticky;
      top: 20px;
      align-self: start;
    }

    label {
      display: block;
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 8px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    textarea,
    input,
    select {
      width: 100%;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(0, 0, 0, 0.22);
